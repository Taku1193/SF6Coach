{
  "name": "sf6-coach",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "npm run build:frontend && npm run build:backend && npm run build:lambda",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:lambda": "mkdir -p artifacts/lambda && esbuild backend/src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=artifacts/lambda/index.js && printf '{\"type\":\"commonjs\"}\\n' > artifacts/lambda/package.json",
    "check": "tsc -p frontend/tsconfig.json --noEmit && tsc -p backend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.772.0",
    "@aws-sdk/lib-dynamodb": "^3.772.0",
    "openai": "^4.100.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/aws-lambda": "^8.10.147",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "esbuild": "^0.25.9",
    "typescript": "^5.8.3",
    "vite": "^6.2.5"
  }
}
